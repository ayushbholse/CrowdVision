{
  "expo": {
    "name": "CrowdVision",
    "slug": "CrowdVision",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/robot-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/robot-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0B1A"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.crowdvision.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A0B1A",
        "foregroundImage": "./assets/robot-icon.png"
      },
      "permissions": [
        "READ_MEDIA_IMAGES",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-sharing",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow CrowdVision to save crowd images to your gallery.",
          "savePhotosPermission": "Allow CrowdVision to save crowd images to your gallery."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow CrowdVision to access your camera for professional crowd analysis."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ed00e763-6a34-4585-9b30-f6866d096284"
      }
    }
  }
}